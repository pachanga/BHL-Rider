<idea-plugin>
    <id>com.bitdotgames.bhl.rider</id>
    <name>BHL</name>
    <vendor url="https://github.com/bitdotgames">bitdotgames</vendor>

    <description><![CDATA[
    LSP client for the <a href="https://github.com/bitdotgames/bhl">BHL</a> (Behaviour Highlevel Language)
    scripting language. Launches the BHL language server (<code>bhl lsp</code>) over stdio and wires it
    up to files with the <code>.bhl</code> extension.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="BHL File"
                  implementationClass="com.bitdotgames.bhl.rider.BhlFileType"
                  fieldName="INSTANCE"
                  language="BHL"
                  extensions="bhl"/>

        <lang.syntaxHighlighterFactory language="BHL"
                                       implementationClass="com.bitdotgames.bhl.rider.highlight.BhlSyntaxHighlighterFactory"/>

        <projectConfigurable parentId="language"
                              instance="com.bitdotgames.bhl.rider.settings.BhlSettingsConfigurable"
                              id="settings.bhl"
                              displayName="BHL"/>

        <platform.lsp.serverSupportProvider
                implementation="com.bitdotgames.bhl.rider.lsp.BhlLspServerSupportProvider"/>

        <toolWindow id="BHL LSP"
                    anchor="bottom"
                    secondary="true"
                    canCloseContents="false"
                    icon="/icons/bhl.svg"
                    factoryClass="com.bitdotgames.bhl.rider.lsp.BhlLspConsoleToolWindowFactory"/>

        <postStartupActivity implementation="com.bitdotgames.bhl.rider.lsp.BhlLspStartupActivity"/>

        <!-- Colors for BHL semantic-token keys; without these, types/variables/parameters
             map to attribute keys that stock IntelliJ schemes leave uncolored. -->
        <additionalTextAttributes scheme="Default" file="colorSchemes/BhlDefault.xml"/>
        <additionalTextAttributes scheme="Darcula" file="colorSchemes/BhlDarcula.xml"/>

        <!-- Rider's built-in LSP client has no signature-help support; bridge Ctrl+P /
             auto-popup to the server's textDocument/signatureHelp ourselves. Registered for
             "TEXT" (not "BHL") because .bhl files have no ParserDefinition and therefore
             fall back to plain-text PSI; the handler itself checks the file type and returns
             null for anything that isn't a .bhl file. -->
        <codeInsight.parameterInfo language="TEXT"
                                   implementationClass="com.bitdotgames.bhl.rider.lsp.BhlParameterInfoHandler"/>

        <!-- BHL keywords/primitive types so the spell checker doesn't flag them as typos
             in .bhl files (which are plain-text PSI — see the parameter-info EP above). -->
        <spellchecker.bundledDictionaryProvider
                implementation="com.bitdotgames.bhl.rider.BhlBundledDictionaryProvider"/>
    </extensions>

    <actions>
        <action id="Bhl.SelectProjectFile"
                class="com.bitdotgames.bhl.rider.actions.SelectBhlProjectFileAction"
                text="Select BHL Project File..."
                description="Choose which bhl.proj to use when the project contains more than one">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
